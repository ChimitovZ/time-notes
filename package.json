{
  "name": "time-notes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "start:server": "tsx server/index.ts",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@tanstack/vue-query": "^5.92.9",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.8.2",
    "openai": "^6.27.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  }
}
